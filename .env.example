# Flask
FLASK_APP=toolkit
FLASK_ENV=development
FLASK_CONFIG=development
SECRET_KEY=dev-secret-key-change-in-production
WTF_CSRF_SECRET_KEY=csrf-secret-key-change-in-production

# Database
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/toolkit
TEST_DATABASE_URL=mysql+pymysql://root:password@localhost:3306/toolkit_test

# Redis
REDIS_URL=redis://localhost:6379/0

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Email (for production)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# File upload
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=./uploads

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Subdomain configuration (for local development)
# Add to /etc/hosts:
# 127.0.0.1 www.toolkit.local
# 127.0.0.1 account.toolkit.local
# 127.0.0.1 settings.toolkit.local
# 127.0.0.1 notice.toolkit.local
# 127.0.0.1 contacts.toolkit.local
# 127.0.0.1 chat.toolkit.local